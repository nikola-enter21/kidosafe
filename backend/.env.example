# Port this NestJS server listens on
PORT=3000

# Base URL of the external scenario-generation API
SCENARIO_API_URL=http://localhost:4000

# Optional bearer token for the scenario API
SCENARIO_API_KEY=your_api_key_here

# Maximum file upload size in bytes (default 10 MB)
MAX_FILE_SIZE=10485760

# CORS origin for the React frontend
CORS_ORIGIN=http://localhost:5173
